.env.example
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=hotel_user
DB_PASSWORD=hotel_password
DB_NAME=hotel_management
DB_SYNCHRONIZE=false
DB_LOGGING=true

JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRATION=7d

# Sciener API Configuration
SCIENER_CLIENT_ID=your_sciener_client_id
SCIENER_CLIENT_SECRET=your_sciener_client_secret
SCIENER_API_URL=https://euopen.sciener.com

# App Configuration
APP_PORT=3000
APP_ENV=development
